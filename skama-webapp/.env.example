# In development:
# - Keep VITE_API_BASE_URL empty to call relative /api and /images routes.
# - Set VITE_API_PROXY_TARGET to your running API host (Swagger example: https://localhost:7157).
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=https://localhost:7157

# In production:
# - Set VITE_API_BASE_URL to the public API URL.
# - VITE_API_PROXY_TARGET is ignored because Vite proxy is dev-only.

# API CORS reminder:
# Add your frontend origin to skama-api appsettings.json (Cors:AllowedOrigins).
